{
  "name": "yuku-codegen",
  "version": "0.5.9",
  "description": "High-performance JavaScript/TypeScript code generator written in Zig",
  "keywords": [
    "ast",
    "codegen",
    "estree",
    "javascript",
    "minifier",
    "napi",
    "printer",
    "typescript"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/yuku-toolchain/yuku"
  },
