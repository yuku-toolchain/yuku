  "comments": [
    {
      "type": "Line",
      "value": " TypeScript assertion wrappers as assignment targets.",
      "start": 0,
      "end": 55
    },
    {
      "type": "Line",
      "value": "",
      "start": 56,
      "end": 58
    },
    {
      "type": "Line",
      "value": " `a!`, `a as T`, `<T>a`, and `a satisfies T` are valid simple assignment",
      "start": 59,
      "end": 133
    },
    {
      "type": "Line",
      "value": " targets so long as what they wrap is itself a simple target (an identifier",
      "start": 134,
      "end": 211
    },
    {
      "type": "Line",
      "value": " or member access). yuku must accept these in assignable position, matching",
      "start": 212,
      "end": 289
    },
    {
      "type": "Line",
      "value": " tsc and oxc. Regression guard for `grammar.expressionToPattern`, which used",
      "start": 290,
      "end": 368
    },
    {
      "type": "Line",
      "value": " to reject every bare assertion in pattern position.",
      "start": 369,
      "end": 423
    },
    {
      "type": "Line",
      "value": " valid: non-null assertion wrapping an identifier or member access",
      "start": 425,
      "end": 493
    },
    {
      "type": "Line",
      "value": " valid: type assertions and `satisfies` behave the same way",
      "start": 541,
      "end": 602
    },
    {
      "type": "Line",
      "value": " valid: a parenthesized assertion is equivalent to the bare form",
      "start": 666,
      "end": 732
    },
    {
      "type": "Line",
      "value": " invalid: the assertion wraps something that is not a simple target, so the",
      "start": 744,
      "end": 821
    },
    {
      "type": "Line",
      "value": " whole expression is still not assignable (oxc rejects this too).",
      "start": 822,
      "end": 889
    },
    {
      "type": "Line",
      "value": " invalid: assertions may only appear in assignment targets, never in a",
      "start": 901,
      "end": 973
    },
    {
      "type": "Line",
      "value": " binding pattern such as a `const` destructuring declaration.",
      "start": 974,
      "end": 1037
    }
  ],
  "diagnostics": [
    {
      "severity": "error",
      "message": "Invalid assignment target",
      "start": 890,
      "end": 894,
      "help": "The expression behind a non-null or type assertion must itself be a simple assignment target, like an identifier or member access, not a call or other expression.",
