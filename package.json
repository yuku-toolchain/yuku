{
	"name": "yuku-root",
	"private": true,
	"scripts": {
		"dev:docs": "bun run --filter './docs' dev",
		"test:tools": "zig build test-tools",
		"format": "zig fmt **/*.zig",
		"test": "bun load-files && bun npm:build && bun test/parser/run.ts",
		"load-files": "bun profiler/load-parser-bench-files && bun test/parser/load test/parser/suite",
		"play": "bun --console-depth=20 test/playground.ts",
		"npm:release": "napi bump",
		"npm:debug": "napi build",
		"npm:build": "napi build --release && zig build gen-estree-decoder && cp ./zig-out/decode.js ./npm/yuku-parser"
	},
	"devDependencies": {
		"@types/bun": "^1.3.11",
		"@types/node": "^25.5.0",
		"fast-deep-equal": "^3.1.3",
		"jest-diff": "^30.3.0",
		"napi-zig": "^0.1.22",
		"typescript": "^6.0.2",
		"yuku-parser": "workspace:*"
	},
	"workspaces": [
		"npm/**/*",
		"docs"
	]
}
