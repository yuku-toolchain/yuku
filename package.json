{
  "name": "yuku-root",
  "private": true,
  "workspaces": [
    "npm/**/*",
    "docs"
  ],
  "scripts": {
    "dev:docs": "bun run --filter './docs' dev",
    "test:tools": "zig build test-tools",
    "test:fuzz": "zig build test --fuzz=200K",
    "test:parser": "bun test/parser/run.ts",
    "test:minifier": "bun test/minifier/run.ts",
    "format": "zig fmt **/*.zig",
    "test": "bun load-files && bun build:npm && bun test:parser && bun test:minifier",
    "load-files": "bun profiler/load-parser-bench-files && bun test/parser/load test/parser/suite",
    "play": "bun build:npm && bun --console-depth=20 test/playground.ts",
    "release:npm": "napi bump",
    "debug:npm": "napi build",
    "build:npm": "napi build --release && zig build gen-estree-decoder && cp ./zig-out/decode.js ./npm/yuku-parser && zig build gen-estree-encoder && cp ./zig-out/encode.js ./npm/yuku-codegen"
  },
  "devDependencies": {
    "@babel/generator": "^7.29.1",
    "@babel/parser": "^7.29.3",
    "@types/babel__generator": "^7.27.0",
    "@types/bun": "^1.3.11",
    "@types/node": "^25.5.0",
    "fast-deep-equal": "^3.1.3",
    "jest-diff": "^30.3.0",
    "napi-zig": "^0.1.39",
    "oxc-minify": "^0.130.0",
    "typescript": "^6.0.2",
    "yuku-codegen": "workspace:*",
    "yuku-minify": "workspace:*",
    "yuku-parser": "workspace:*"
  }
}
